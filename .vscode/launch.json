{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Greet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_greet.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Add",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_add.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-q"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}